<Window x:Class="OpenQuickHost.AddJsonExtensionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenQuickHost"
        Title="JSON 扩展编辑器"
        Width="1080"
        Height="720"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DialogWindow}">
    <Border Margin="15"
            CornerRadius="12"
            Background="#FF161616"
            BorderBrush="#FF2A2A2A"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText"
                       Text="Add Single-file JSON Extension"
                       Style="{StaticResource TitleText}" />
            
            <TextBlock Grid.Row="1"
                       Margin="0,8,0,0"
                       Text="可以直接编辑 JSON，也可以先填写左侧表单，再生成 JSON。保存后会自动写入本地并同步到云端。"
                       Style="{StaticResource DescriptionText}" />

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Background="#FF1E1E1E"
                        BorderBrush="#FF2A2A2A"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="基础字段" Foreground="White" FontSize="13" FontWeight="SemiBold" />

                            <TextBlock Text="扩展 ID" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="IdBox" TextChanged="IconPreviewContext_TextChanged" />

                            <TextBlock Text="名称" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="NameBox" TextChanged="IconPreviewContext_TextChanged" />

                            <TextBlock Text="版本号" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="VersionBox" />

                            <TextBlock Text="分类" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="CategoryBox" />

                            <TextBlock Text="描述" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="DescriptionBox" AcceptsReturn="True" TextWrapping="Wrap" Height="72" VerticalScrollBarVisibility="Auto" />

                            <TextBlock Text="关键词" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="KeywordsBox" ToolTip="多个关键词用英文逗号分隔，例如 json, extension, docs" />

                            <Border Margin="0,18,0,0"
                                    Padding="12"
                                    Background="#FF161616"
                                    BorderBrush="#FF2A2A2A"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="扩展图标" Foreground="White" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock Text="可直接选内置图标，也可以选择你自己的图片。最终会写入 manifest.json 的 icon 字段。"
                                               Foreground="#FF9CA3AF"
                                               FontSize="12"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Border Width="56"
                                                Height="56"
                                                CornerRadius="14"
                                                Background="#FF38BDF8"
                                                BorderBrush="#FF2A2A2A"
                                                BorderThickness="1">
                                            <Grid>
                                                <Image x:Name="IconPreviewImage"
                                                       Margin="10"
                                                       Stretch="Uniform"
                                                       Visibility="Collapsed" />
                                                <Viewbox x:Name="IconPreviewVectorHost"
                                                         Margin="12"
                                                         Visibility="Collapsed">
                                                    <Canvas Width="24" Height="24">
                                                        <Path x:Name="IconPreviewVector"
                                                              Fill="White"
                                                              Stretch="Uniform" />
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock x:Name="IconPreviewGlyph"
                                                           Text="E"
                                                           Foreground="White"
                                                           FontSize="22"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="Collapsed" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="当前图标预览" Foreground="White" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock x:Name="IconPreviewHintText"
                                                       Text="未设置图标时会回退为字母标识。"
                                                       Foreground="#FF9CA3AF"
                                                       FontSize="12"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Text="icon 值" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                                    <TextBox x:Name="IconBox"
                                             TextChanged="IconBox_TextChanged"
                                             ToolTip="支持 mdi:search、app:wechat、icons/logo.png、绝对路径、https 图片地址" />

                                    <DockPanel Margin="0,14,0,0">
                                        <TextBlock Text="内置图标库"
                                                   Foreground="#FFB8B8B8"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                            <Button Content="清空图标"
                                                    Style="{StaticResource SecondaryBtn}"
                                                    Height="28"
                                                    Padding="10,0"
                                                    Margin="0,0,8,0"
                                                    Click="ClearIconButton_Click" />
                                            <Button Content="选择图片"
                                                    Style="{StaticResource SecondaryBtn}"
                                                    Height="28"
                                                    Padding="10,0"
                                                    Click="PickIconImageButton_Click" />
                                        </StackPanel>
                                    </DockPanel>

                                    <ScrollViewer Margin="0,8,0,0"
                                                  Height="170"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="BuiltInIconsList">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type local:ExtensionIconOption}">
                                                    <Button Width="72"
                                                            Height="72"
                                                            Margin="0,0,8,8"
                                                            Padding="0"
                                                            Tag="{Binding Reference}"
                                                            Click="BuiltInIconButton_Click"
                                                            ToolTip="{Binding Reference}"
                                                            Background="#FF1E1E1E"
                                                            BorderBrush="#FF2A2A2A"
                                                            BorderThickness="1">
                                                        <StackPanel VerticalAlignment="Center">
                                                            <Border Width="34"
                                                                    Height="34"
                                                                    CornerRadius="10"
                                                                    Background="#FF2563EB"
                                                                    HorizontalAlignment="Center">
                                                                <Viewbox Margin="7">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="{Binding Geometry}" Fill="White" Stretch="Uniform" />
                                                                    </Canvas>
                                                                </Viewbox>
                                                            </Border>
                                                            <TextBlock Text="{Binding Label}"
                                                                       Foreground="White"
                                                                       FontSize="10"
                                                                       Margin="0,6,0,0"
                                                                       HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="打开目标" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="OpenTargetBox" />

                            <TextBlock Text="全局快捷键" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="GlobalShortcutBox" />

                            <TextBlock Text="热键行为" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="HotkeyBehaviorBox" ToolTip="例如 show-view" />

                            <TextBlock Text="脚本运行时" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="RuntimeBox" ToolTip="例如 powershell" />

                            <TextBlock Text="脚本入口" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="EntryBox" ToolTip="例如 main.ps1" />

                            <TextBlock Text="权限" Foreground="#FFB8B8B8" FontSize="12" Margin="0,14,0,6" />
                            <TextBox x:Name="PermissionsBox" ToolTip="多个权限用英文逗号分隔" />

                            <Border Margin="0,18,0,0"
                                    Padding="12"
                                    Background="#FF161616"
                                    BorderBrush="#FF2A2A2A"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <CheckBox x:Name="InlineScriptModeCheckBox"
                                              Content="脚本模式（单 JSON 内联动作）"
                                              Foreground="White"
                                              Checked="InlineScriptModeCheckBox_Changed"
                                              Unchecked="InlineScriptModeCheckBox_Changed" />
                                    <TextBlock Text="适合轻量扩展。启用后会使用 entryMode = inline，并把代码保存在 script.source。"
                                               Foreground="#FF9CA3AF"
                                               FontSize="12"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap" />

                                    <TextBlock x:Name="InlineRuntimeLabel"
                                               Text="内联运行时"
                                               Foreground="#FFB8B8B8"
                                               FontSize="12"
                                               Margin="0,14,0,6"
                                               Visibility="Collapsed" />
                                    <ComboBox x:Name="InlineRuntimeBox"
                                              SelectionChanged="InlineRuntimeBox_SelectionChanged"
                                              Visibility="Collapsed">
                                        <ComboBoxItem Content="C# 动作" Tag="csharp" IsSelected="True" />
                                        <ComboBoxItem Content="PowerShell 脚本" Tag="powershell" />
                                    </ComboBox>

                                    <TextBlock x:Name="ScriptSourceLabel"
                                               Text="内联代码"
                                               Foreground="#FFB8B8B8"
                                               FontSize="12"
                                               Margin="0,14,0,6"
                                               Visibility="Collapsed" />
                                    <TextBox x:Name="ScriptSourceBox"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             TextWrapping="NoWrap"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             Height="180"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             Visibility="Collapsed" />

                                    <TextBlock x:Name="TestInputLabel"
                                               Text="测试输入"
                                               Foreground="#FFB8B8B8"
                                               FontSize="12"
                                               Margin="0,14,0,6"
                                               Visibility="Collapsed" />
                                    <TextBox x:Name="TestInputBox"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Height="72"
                                             VerticalScrollBarVisibility="Auto"
                                             Visibility="Collapsed" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="2"
                        Background="#FF1E1E1E"
                        BorderBrush="#FF2A2A2A"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <TextBlock Text="JSON 清单"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <Button Content="测试执行"
                                        Style="{StaticResource SecondaryBtn}"
                                        Height="30"
                                        Padding="12,0"
                                        Margin="0,0,8,0"
                                        Click="TestRunButton_Click" />
                                <Button Content="查看日志"
                                        Style="{StaticResource SecondaryBtn}"
                                        Height="30"
                                        Padding="12,0"
                                        Margin="0,0,8,0"
                                        Click="OpenLogButton_Click" />
                                <Button Content="复制提示词"
                                        Style="{StaticResource SecondaryBtn}"
                                        Height="30"
                                        Padding="12,0"
                                        Margin="0,0,8,0"
                                        Click="CopyPromptButton_Click" />
                                <Button Content="从 JSON 解析"
                                        Style="{StaticResource SecondaryBtn}"
                                        Height="30"
                                        Padding="12,0"
                                        Margin="0,0,8,0"
                                        Click="ParseJsonButton_Click" />
                                <Button Content="从表单生成"
                                        Style="{StaticResource SecondaryBtn}"
                                        Height="30"
                                        Padding="12,0"
                                        Click="GenerateJsonButton_Click" />
                            </StackPanel>
                        </DockPanel>

                        <TextBox Grid.Row="1"
                                 x:Name="JsonEditor"
                                 Margin="0,14,0,0"
                                 Padding="15"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="#FF161616"
                                 BorderBrush="#FF2A2A2A"
                                 BorderThickness="1"
                                 Foreground="#FFD4D4D4" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="3" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="ErrorText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="#FFEF4444"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />
                
                <Button Grid.Column="1"
                        Content="取消"
                        Style="{StaticResource SecondaryBtn}"
                        Width="100"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click" />
                
                <Button x:Name="SaveButton"
                        Grid.Column="2"
                        Content="保存扩展"
                        Style="{StaticResource PrimaryBtn}"
                        Width="140"
                        Click="SaveButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
