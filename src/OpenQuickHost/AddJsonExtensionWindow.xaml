<Window x:Class="OpenQuickHost.AddJsonExtensionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenQuickHost"
        Width="1200"
        Height="880"
        MinWidth="1080"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        Style="{StaticResource DialogWindow}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#FF1C1C1C" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FF252525" />
        <SolidColorBrush x:Key="Surface2Brush" Color="#FF2A2A2A" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#12FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#1FFFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF3B82F6" />
        <SolidColorBrush x:Key="AccentDeepBrush" Color="#FF2563EB" />
        <SolidColorBrush x:Key="AccentGlowBrush" Color="#223B82F6" />
        <SolidColorBrush x:Key="GreenBrush" Color="#FF34D399" />
        <SolidColorBrush x:Key="RedBrush" Color="#FFF87171" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFF0F0F5" />
        <SolidColorBrush x:Key="Text2Brush" Color="#FF9090A8" />
        <SolidColorBrush x:Key="Text3Brush" Color="#FF5A5A72" />

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Text2Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Surface2Brush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="18,10" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentDeepBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentDeepBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChipButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Background" Value="{StaticResource Surface2Brush}" />
            <Setter Property="Foreground" Value="{StaticResource Text2Brush}" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="FontSize" Value="12" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentGlowBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="24" />
        </Style>
    </Window.Resources>

    <Border Margin="15"
            Background="#E61C1C1C"
            BorderBrush="#FF333333"
            BorderThickness="1"
            CornerRadius="16"
            SnapsToDevicePixels="True"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <Grid Background="{StaticResource BgBrush}" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Area -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="28,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent" Cursor="Hand">
                    <TextBlock FontSize="26" FontWeight="Bold">
                        <Run x:Name="PageHeaderPrefix" Text="编辑" Foreground="{StaticResource TextBrush}" />
                        <Run x:Name="PageHeaderAccent" Text="扩展" Foreground="{StaticResource AccentBrush}" />
                    </TextBlock>
                    <TextBlock x:Name="HeaderDescription"
                             Margin="0,6,0,0"
                             Text="直接修改 JSON，验证通过后可以测试并保存。"
                             Foreground="{StaticResource Text2Brush}"
                             FontSize="13.5" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button x:Name="ManualModeButton"
                            Margin="0,0,12,0"
                            Content="手动编辑"
                            Style="{StaticResource GhostButtonStyle}"
                            Height="36"
                            Padding="16,0"
                            Click="ManualModeButton_Click" />

                    <Button x:Name="CloseButton"
                            Width="36"
                            Height="36"
                            Style="{StaticResource GhostButtonStyle}"
                            Padding="0"
                            Click="CancelButton_Click"
                            ToolTip="关闭">
                        <TextBlock Text="✕" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="28,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Column: Form & Controls -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                <StackPanel>
                    <!-- Templates Section -->
                    <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="模板" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" />
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="打开桌面" Style="{StaticResource ChipButtonStyle}" Click="ManualTemplateButton_Click" Tag="base" />
                                <Button Content="打开记事本" Style="{StaticResource ChipButtonStyle}" Click="ManualTemplateButton_Click" Tag="open" />
                                <Button Content="网页搜索" Style="{StaticResource ChipButtonStyle}" Click="ManualTemplateButton_Click" Tag="search" />
                                <Button Content="内联脚本" Style="{StaticResource ChipButtonStyle}" Click="ManualTemplateButton_Click" Tag="script" />
                                <Button Content="前台窗口" Style="{StaticResource ChipButtonStyle}" Click="ManualTemplateButton_Click" Tag="foreground" />
                                <Button Content="模拟粘贴" Style="{StaticResource ChipButtonStyle}" Click="ManualTemplateButton_Click" Tag="clipboard" />
                                <Button Content="选中内容" Style="{StaticResource ChipButtonStyle}" Click="ManualTemplateButton_Click" Tag="selection" />
                                <Button Content="C# 脚本" Style="{StaticResource ChipButtonStyle}" Click="ManualTemplateButton_Click" Tag="csharp" />
                                <Button Content="时间格式" Style="{StaticResource ChipButtonStyle}" Click="ManualTemplateButton_Click" Tag="timestamp" />
                                <Button Content="翻译工作区" Style="{StaticResource ChipButtonStyle}" Click="ManualTemplateButton_Click" Tag="translate" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Data Sync Section -->
                    <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="同步" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Text="左侧表单与右侧 JSON 双向同步。" Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,4,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Content="从 JSON 解析" Style="{StaticResource GhostButtonStyle}" Click="ParseManualJsonButton_Click" Padding="14,6" Height="32" />
                                <Button Content="同步到 JSON" Style="{StaticResource GhostButtonStyle}" Margin="10,0,0,0" Click="GenerateManualJsonButton_Click" Padding="14,6" Height="32" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="基本信息" Foreground="{StaticResource TextBrush}" FontSize="15" FontWeight="Bold" Margin="0,0,0,16" />

                    <TextBlock Text="图标预览" Foreground="{StaticResource TextBrush}" FontSize="15" FontWeight="Bold" Margin="0,0,0,16" />
                    <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,24">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="64" Height="64" CornerRadius="16" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
                                    <Grid>
                                        <Image x:Name="IconPreviewImage" Margin="12" Stretch="Uniform" Visibility="Collapsed" />
                                        <Viewbox x:Name="IconPreviewVectorHost" Margin="14" Visibility="Collapsed">
                                            <Canvas Width="24" Height="24">
                                                <Path x:Name="IconPreviewVector" Fill="White" Stretch="Uniform" />
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock x:Name="IconPreviewGlyph" Text="E" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
                                    </Grid>
                                </Border>
                                <TextBlock x:Name="IconPreviewHintText" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Text2Brush}" FontSize="12.5" TextWrapping="Wrap" MaxWidth="280" />
                            </StackPanel>

                            <TextBlock Text="icon 属性" Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,16,0,8" />
                            <TextBox x:Name="IconBox" Padding="12,9" Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" />

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="图片图标" Style="{StaticResource GhostButtonStyle}" Click="PickIconImageButton_Click" Padding="14,6" Height="32" />
                                <Button Content="清空" Style="{StaticResource GhostButtonStyle}" Margin="10,0,0,0" Click="ClearIconButton_Click" Padding="14,6" Height="32" />
                            </StackPanel>

                            <ItemsControl x:Name="BuiltInIconsList" Visibility="Collapsed" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="扩展 ID" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="IdBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" TextChanged="IconPreviewContext_TextChanged" />

                    <TextBlock Text="名称" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="NameBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" TextChanged="IconPreviewContext_TextChanged" />

                    <TextBlock Text="版本号" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="VersionBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="分类" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="CategoryBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="描述" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="DescriptionBox" Padding="14,11" AcceptsReturn="True" TextWrapping="Wrap" Height="86" VerticalScrollBarVisibility="Auto" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="关键词 (逗号分隔)" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="KeywordsBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,24" />

                    <TextBlock Text="启动配置" Foreground="{StaticResource TextBrush}" FontSize="15" FontWeight="Bold" Margin="0,0,0,16" />
                    <Border Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="自启动模式" Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,0,0,8" />
                            <TextBox x:Name="StartupModeBox" Padding="12,9" Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,14" ToolTip="例如: on_app_launch" />

                            <TextBlock Text="定时计划" Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,0,0,8" />
                            <TextBox x:Name="StartupScheduleBox" Padding="12,9" Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" ToolTip="Cron 表达式或简单描述" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="核心逻辑" Foreground="{StaticResource TextBrush}" FontSize="15" FontWeight="Bold" Margin="0,0,0,16" />
                    
                    <TextBlock Text="打开目标" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="OpenTargetBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="搜索前缀 (逗号分隔)" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="QueryPrefixesBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="搜索模板" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="QueryTargetTemplateBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="全局快捷键" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="GlobalShortcutBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="运行时" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="RuntimeBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="入口模式" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="EntryModeBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="入口路径" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="EntryBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="内联脚本" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="ScriptSourceBox" Padding="14,11" AcceptsReturn="True" TextWrapping="NoWrap" Height="180" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" Margin="0,0,0,24" />

                    <TextBlock Text="热键行为" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="HotkeyBehaviorBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,18" />

                    <TextBlock Text="权限 (逗号分隔)" Foreground="{StaticResource Text2Brush}" FontSize="12.5" Margin="0,0,0,8" />
                    <TextBox x:Name="PermissionsBox" Padding="14,11" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Foreground="{StaticResource TextBrush}" Margin="0,0,0,24" />

                </StackPanel>
            </ScrollViewer>

            <!-- Right Column: JSON Editor -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="编辑扩展 JSON" Foreground="{StaticResource TextBrush}" FontSize="17" FontWeight="Bold" />
                            <TextBlock Text="直接修改代码，实时同步或保存。" Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,4,0,0" />
                        </StackPanel>
                        <Button x:Name="ManualCopyPromptButton"
                                Grid.Column="1"
                                Content="复制提示词"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="36"
                                Padding="18,0"
                                VerticalAlignment="Center"
                                Click="ManualCopyPromptButton_Click" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1.5" CornerRadius="12">
                    <Grid>
                        <TextBox x:Name="ManualJsonInputBox"
                                 Padding="18"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 FontFamily="Consolas"
                                 FontSize="13.5"
                                 TextChanged="ManualJsonInputBox_TextChanged" />
                        
                        <Border x:Name="JsonStatusBadge"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Right"
                                Margin="0,0,16,16"
                                Padding="10,5"
                                CornerRadius="12"
                                Background="#AA111111"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="ManualJsonStatusDot" Width="7" Height="7" Fill="{StaticResource Text3Brush}" VerticalAlignment="Center" />
                                <TextBlock x:Name="ManualJsonStatusText" Margin="8,0,0,0" Text="等待输入" Foreground="{StaticResource Text3Brush}" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Test Controls -->
                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="ManualTestExtensionButton"
                                Content="测试扩展运行"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="36"
                                Padding="20,0"
                                FontWeight="SemiBold"
                                Click="ManualTestExtensionButton_Click" />
                    </StackPanel>

                    <Border x:Name="ManualTestResultPanel"
                            Background="{StaticResource Surface2Brush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="18"
                            Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="测试执行日志" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                                <Button x:Name="ManualCopyTestFailureButton"
                                        Grid.Column="1"
                                        Content="复制错误"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Height="30"
                                        Padding="12,0"
                                        Visibility="Collapsed"
                                        Click="ManualCopyTestFailureButton_Click" />
                            </Grid>
                            <TextBlock x:Name="ManualTestSummaryText" Margin="0,4,0,10" Foreground="{StaticResource Text2Brush}" FontSize="12.5" TextWrapping="Wrap" />
                            <TextBox x:Name="ManualTestLogTextBox"
                                     Height="160"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#FF101014"
                                     BorderThickness="0"
                                     Foreground="{StaticResource Text2Brush}"
                                     FontFamily="Consolas"
                                     FontSize="12" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Footer Area -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="28,20">
            <Grid>
                <TextBlock x:Name="ErrorText"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="{StaticResource RedBrush}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Visibility="Collapsed" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="SaveButton"
                            Content="保存修改 →"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="42"
                            Padding="28,0"
                            FontSize="15"
                            Click="SaveButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Hidden Legacy Layer (Kept for code-behind compatibility only) -->
        <Grid Visibility="Collapsed" IsHitTestVisible="False" Width="0" Height="0">
            <Grid x:Name="WizardHeaderPanel" />
            <Border x:Name="Step1Panel" />
            <Border x:Name="Step2Panel" />
            <Border x:Name="Step3Panel" />
            <Grid x:Name="ManualEditorPanel" />
            <TextBox x:Name="AiRequestBox" />
            <TextBlock x:Name="AiRequestPlaceholder" />
            <TextBox x:Name="AiPromptPreviewBox" />
            <TextBlock x:Name="AiPromptPlaceholder" />
            <TextBox x:Name="AiJsonInputBox" />
            <TextBlock x:Name="AiJsonPlaceholder" />
            <Button x:Name="TestExtensionButton" />
            <Button x:Name="CopyTestFailureButton" />
            <Border x:Name="TestResultPanel" />
            <TextBlock x:Name="TestSummaryText" />
            <TextBox x:Name="TestLogTextBox" />
            <Button x:Name="GoStep2Button" />
            <Button x:Name="GoStep3Button" />
            <Button x:Name="CopyAiGuidePromptButton" />
            <TextBlock x:Name="AiPromptStatusText" />
            <Ellipse x:Name="AiPromptStatusDot" />
            <TextBlock x:Name="AiJsonStatusText" />
            <Ellipse x:Name="JsonStatusDot" />
            <Border x:Name="Step1Dot" />
            <TextBlock x:Name="Step1DotText" />
            <Border x:Name="Step2Dot" />
            <TextBlock x:Name="Step2DotText" />
            <Border x:Name="Step3Dot" />
            <TextBlock x:Name="Step3DotText" />
            <TextBlock x:Name="Step1Label" />
            <TextBlock x:Name="Step2Label" />
            <TextBlock x:Name="Step3Label" />
            <Border x:Name="StepLine1" />
            <Border x:Name="StepLine2" />
