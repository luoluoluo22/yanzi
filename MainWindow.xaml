<Window x:Class="OpenQuickHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenQuickHost"
        mc:Ignorable="d"
        Title="燕子"
        Width="860"
        Height="580"
        MinWidth="760"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        AllowsTransparency="True"
        KeyDown="Window_KeyDown">
    
    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="WindowBackground">#FF1C1C1C</Color>
        <Color x:Key="BorderColor">#FF333333</Color>
        <Color x:Key="SecondaryText">#FF8E8E8E</Color>
        <Color x:Key="AccentColor">#FF3B82F6</Color>
        
        <!-- Brushes -->
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackground}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryText}" />
        
        <!-- Animations -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2" />
        </Storyboard>
    </Window.Resources>

    <Border Margin="15"
            CornerRadius="16"
            Background="#E61C1C1C"
            BorderBrush="#FF333333"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Search -->
                <RowDefinition Height="Auto" /> <!-- Banner -->
                <RowDefinition Height="*" />    <!-- List -->
                <RowDefinition Height="Auto" /> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Search Bar -->
            <Grid Grid.Row="0" Margin="20,15,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search Icon -->
                <TextBlock VerticalAlignment="Center"
                           FontSize="20"
                           Foreground="#FFAAAAAA"
                           Text="⌕" 
                           Margin="5,0,15,0"/>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         FontSize="20"
                         Foreground="White"
                         Background="Transparent"
                         BorderThickness="0"
                         CaretBrush="#FF3B82F6"
                         VerticalAlignment="Center"
                         Padding="0,5"
                         TextChanged="SearchBox_TextChanged"
                         PreviewKeyDown="SearchBox_PreviewKeyDown" />
                
                <!-- Search Box Placeholder -->
                <TextBlock Grid.Column="1"
                           IsHitTestVisible="False"
                           Text="Search for apps and commands..."
                           VerticalAlignment="Center"
                           Foreground="#FF555555"
                           FontSize="20"
                           Margin="2,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Right Side Tags -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FF282828" 
                            CornerRadius="6" 
                            Padding="8,4" 
                            Margin="0,0,8,0">
                        <TextBlock Text="Quick AI" 
                                   Foreground="#FF888888" 
                                   FontSize="12" 
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#FF333333" 
                            CornerRadius="4" 
                            Padding="6,2" 
                            BorderBrush="#FF444444" 
                            BorderThickness="1">
                        <TextBlock Text="Tab" 
                                   Foreground="#FFAAAAAA" 
                                   FontSize="10" 
                                   FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Row="0" Height="1" Fill="#FF2A2A2A" VerticalAlignment="Bottom" Margin="0,5,0,0"/>

            <!-- 2. "What's New" Banner -->
            <Border Grid.Row="1" 
                    Margin="20,10,20,5" 
                    Padding="12,10" 
                    CornerRadius="8" 
                    Background="#FF252525"
                    BorderBrush="#FF333333"
                    BorderThickness="1">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="24" CornerRadius="6" Background="#FFEF4444" Margin="0,0,12,0">
                            <TextBlock Text="::" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="See what's new" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="v0.55.0.0" Foreground="#FF888888" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="Changelog" 
                               HorizontalAlignment="Right" 
                               VerticalAlignment="Center" 
                               Foreground="#FF888888" 
                               FontSize="13" 
                               Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- 3. List Content -->
            <Grid Grid.Row="2" Margin="10,5,10,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Suggestions" 
                           Margin="12,10,0,5" 
                           Foreground="#FF666666" 
                           FontSize="12" 
                           FontWeight="SemiBold"/>

                <ListBox x:Name="CommandList"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding FilteredCommands}"
                         SelectedItem="{Binding SelectedCommand, Mode=TwoWay}"
                         ContextMenuOpening="CommandList_ContextMenuOpening"
                         MouseDoubleClick="CommandList_MouseDoubleClick"
                         PreviewMouseRightButtonDown="CommandList_PreviewMouseRightButtonDown"
                         PreviewKeyDown="CommandList_PreviewKeyDown"
                         SelectionChanged="CommandList_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden">
                    
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="CreateDesktopShortcutMenuItem"
                                      Header="添加桌面快捷方式"
                                      Click="CreateDesktopShortcutMenuItem_Click" />
                            <Separator />
                            <MenuItem x:Name="RenameCommandMenuItem"
                                      Header="重命名"
                                      Click="RenameCommandMenuItem_Click" />
                            <MenuItem x:Name="EditExtensionMenuItem"
                                      Header="编辑扩展"
                                      Click="EditExtensionMenuItem_Click" />
                            <MenuItem x:Name="DeleteExtensionMenuItem"
                                      Header="删除"
                                      Click="DeleteExtensionMenuItem_Click" />
                        </ContextMenu>
                    </ListBox.ContextMenu>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="4,2,4,2" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Root"
                                                Padding="12,8"
                                                CornerRadius="8"
                                                Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#FF2D2D2D" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#FF252525" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:CommandItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon Area -->
                                <Border Width="32"
                                        Height="32"
                                        CornerRadius="8"
                                        Background="{Binding AccentBrush}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Glyph}"
                                               FontSize="14"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </Border>

                                <!-- Text Area -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="White" />
                                        <TextBlock Text="{Binding Category}"
                                                   Margin="8,0,0,0"
                                                   Foreground="#FF666666"
                                                   FontSize="12"
                                                   VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Subtitle}"
                                               Margin="0,2,0,0"
                                               Foreground="#FF888888"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- Action Label -->
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding ItemKindLabel}" 
                                           Foreground="#FF666666" 
                                           FontSize="12" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,5,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- 4. Footer -->
            <Border Grid.Row="3" Background="#FF161616" CornerRadius="0,0,16,16" Padding="20,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="≡" Foreground="#FF666666" FontSize="16" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SyncStatus}" Foreground="#FF666666" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Actions" Foreground="#FF888888" FontSize="12" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                            <Border Background="#FF282828" CornerRadius="3" Padding="4,2" Margin="0,0,4,0" VerticalAlignment="Center">
                                <TextBlock Text="Ctrl" Foreground="#FF888888" FontSize="10"/>
                            </Border>
                            <Border Background="#FF282828" CornerRadius="3" Padding="4,2" VerticalAlignment="Center">
                                <TextBlock Text="K" Foreground="#FF888888" FontSize="10"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
