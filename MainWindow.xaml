<Window x:Class="OpenQuickHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenQuickHost"
        mc:Ignorable="d"
        Title="燕子"
        Width="700"
        Height="580"
        MinWidth="400"
        MinHeight="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        AllowsTransparency="True"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">
    
    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="WindowBackground">#FF1C1C1C</Color>
        <Color x:Key="BorderColor">#FF333333</Color>
        <Color x:Key="SecondaryText">#FF8E8E8E</Color>
        <Color x:Key="AccentColor">#FF3B82F6</Color>
        
        <!-- Brushes -->
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackground}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryText}" />

        <Style x:Key="QuickMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="12,12" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1AFFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#10FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#25FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Animations -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2" />
        </Storyboard>
    </Window.Resources>

    <Border Margin="15"
            CornerRadius="16"
            Background="#E61C1C1C"
            BorderBrush="#FF333333"
            BorderThickness="1"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Search -->
                <RowDefinition Height="*" />    <!-- List -->
                <RowDefinition Height="Auto" /> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Search Bar -->
            <Grid Grid.Row="0" Margin="20,15,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search Icon -->
                <TextBlock VerticalAlignment="Center"
                           FontSize="20"
                           Foreground="#FFAAAAAA"
                           Text="⌕" 
                           Margin="5,0,15,0"/>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         FontSize="20"
                         Foreground="White"
                         Background="Transparent"
                         BorderThickness="0"
                         CaretBrush="#FF3B82F6"
                         VerticalAlignment="Center"
                         Padding="0,5"
                         TextChanged="SearchBox_TextChanged"
                         PreviewKeyDown="SearchBox_PreviewKeyDown" />
                
                <!-- Search Box Placeholder -->
                <TextBlock Grid.Column="1"
                           IsHitTestVisible="False"
                           Text="Search for apps and commands..."
                           VerticalAlignment="Center"
                           Foreground="#FF555555"
                           FontSize="20"
                           Margin="2,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Grid.Column="2"
                        Width="32"
                        Height="32"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTip="{Binding PinButtonTooltip}"
                        Click="PinAutoHideButton_Click"
                        Style="{StaticResource QuickMenuButtonStyle}">
                    <Path Data="M14,3L21,10L18,11L15,18L13,18L13,12L8,17L7,16L12,11L6,11L6,9L13,8L14,3Z"
                          Fill="{Binding PinButtonBrush}"
                          Height="14"
                          Width="14"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Row="0" Height="1" Fill="#FF2A2A2A" VerticalAlignment="Bottom" Margin="0,5,0,0"/>

            <!-- 2. List Content -->
            <Grid Grid.Row="1" Margin="10,5,10,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Suggestions" 
                           Margin="12,10,0,5" 
                           Foreground="#FF666666" 
                           FontSize="12" 
                           FontWeight="SemiBold"/>

                <ListBox x:Name="CommandList"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding FilteredCommands}"
                         SelectedItem="{Binding SelectedCommand, Mode=TwoWay}"
                         ContextMenuOpening="CommandList_ContextMenuOpening"
                         MouseDoubleClick="CommandList_MouseDoubleClick"
                         PreviewMouseRightButtonDown="CommandList_PreviewMouseRightButtonDown"
                         PreviewKeyDown="CommandList_PreviewKeyDown"
                         SelectionChanged="CommandList_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden">
                    
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="CreateDesktopShortcutMenuItem"
                                      Header="添加桌面快捷方式"
                                      Click="CreateDesktopShortcutMenuItem_Click">
                                <MenuItem.Icon>
                                    <Path Data="M10,2V4.5L12,6.5V10H18V6.5L20,4.5V2M15,12A3,3 0 0,0 12,15A3,3 0 0,0 15,18A3,3 0 0,0 18,15A3,3 0 0,0 15,12Z" Fill="#A0FFFFFF" Stretch="Uniform" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem x:Name="SetCommandShortcutMenuItem"
                                      Header="设置快捷键"
                                      Click="SetCommandShortcutMenuItem_Click">
                                <MenuItem.Icon>
                                    <Path Data="M7,12V7H12A5,5 0 0,1 17,12A5,5 0 0,1 12,17H7V12M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2Z" Fill="#A0FFFFFF" Stretch="Uniform" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="RenameCommandMenuItem"
                                      Header="重命名"
                                      Click="RenameCommandMenuItem_Click">
                                <MenuItem.Icon>
                                    <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" Fill="#A0FFFFFF" Stretch="Uniform" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="EditExtensionMenuItem"
                                      Header="编辑扩展"
                                      Click="EditExtensionMenuItem_Click">
                                <MenuItem.Icon>
                                    <Path Data="M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25M21.41,6.34L17.66,2.59L16.06,4.19L19.81,7.94L21.41,6.34Z" Fill="#A0FFFFFF" Stretch="Uniform" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="DeleteExtensionMenuItem"
                                      Header="删除"
                                      Click="DeleteExtensionMenuItem_Click">
                                <MenuItem.Icon>
                                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="#EF4444" Stretch="Uniform" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem x:Name="AddToQuickPanelMenuItem"
                                      Header="添加到快捷面板"
                                      Click="AddToQuickPanelMenuItem_Click">
                                <MenuItem.Icon>
                                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="#A0FFFFFF" Stretch="Uniform" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </ListBox.ContextMenu>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="4,2,4,2" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Root"
                                                Padding="12,8"
                                                CornerRadius="8"
                                                Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#FF2D2D2D" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#FF252525" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:CommandItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon Area -->
                                <Border Width="32"
                                        Height="32"
                                        CornerRadius="8"
                                        Background="{Binding AccentBrush}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Glyph}"
                                               FontSize="14"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </Border>

                                <!-- Text Area -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="White" />
                                        <TextBlock Text="{Binding Category}"
                                                   Margin="8,0,0,0"
                                                   Foreground="#FF666666"
                                                   FontSize="12"
                                                   VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Subtitle}"
                                               Margin="0,2,0,0"
                                               Foreground="#FF888888"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- Action Label -->
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="8,0,5,0">
                                    <Border Background="#FF282828"
                                            BorderBrush="#FF3A3A3A"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,4"
                                            Margin="0,0,8,0"
                                            Visibility="{Binding HasGlobalShortcut, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding ShortcutLabel}"
                                                   Foreground="#FFACACAC"
                                                   FontSize="10"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Text="{Binding ItemKindLabel}" 
                                               Foreground="#FF666666" 
                                               FontSize="12" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Border Grid.Row="1"
                    Margin="16,10,16,8"
                    Padding="18"
                    Background="#F11B1B1B"
                    BorderBrush="#FF323232"
                    BorderThickness="1"
                    CornerRadius="14"
                    Panel.ZIndex="20"
                    Visibility="{Binding IsHostedViewOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Width="34"
                                Height="34"
                                Background="#FF262626"
                                BorderBrush="#FF363636"
                                BorderThickness="1"
                                Foreground="White"
                                FontSize="14"
                                Click="CloseHostedViewButton_Click">
                            <TextBlock Text="←"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>

                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding HostedViewTitle}"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding HostedViewSubtitle}"
                                       Foreground="#FF8A8A8A"
                                       FontSize="12"
                                       Margin="0,3,0,0" />
                        </StackPanel>

                        <Border Grid.Column="2"
                                Background="#FF262626"
                                BorderBrush="#FF363636"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,5"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding HostedViewCommandLabel}"
                                       Foreground="#FFB6B6B6"
                                       FontSize="11" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#FF202020"
                                BorderBrush="#FF2E2E2E"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="{Binding HostedViewInputLabel}"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="SemiBold" />

                                <Grid Grid.Row="1" Margin="0,10,0,0">
                                    <TextBox x:Name="HostedViewInputBox"
                                             Text="{Binding HostedViewInput, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             TextWrapping="Wrap"
                                             Background="#FF171717"
                                             BorderBrush="#FF2E2E2E"
                                             BorderThickness="1"
                                             Foreground="White"
                                             CaretBrush="#FF3B82F6"
                                             Padding="12"
                                             FontSize="14"
                                             TextChanged="HostedViewInputBox_TextChanged" />

                                    <TextBlock IsHitTestVisible="False"
                                               Margin="14,12,14,0"
                                               VerticalAlignment="Top"
                                               Foreground="#FF555555"
                                               Text="{Binding HostedViewInputPlaceholder}"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=HostedViewInputBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="#FF202020"
                                BorderBrush="#FF2E2E2E"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="{Binding HostedViewOutputLabel}"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="SemiBold" />

                                <Border Grid.Row="1"
                                        Margin="0,10,0,0"
                                        Background="#FF171717"
                                        BorderBrush="#FF2E2E2E"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding HostedViewOutput}"
                                                   Foreground="#FFE5E5E5"
                                                   FontSize="14"
                                                   TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding HostedViewStatus}"
                                   Foreground="#FF818181"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="2,0,14,0" />

                        <Button Grid.Column="1"
                                Content="{Binding HostedViewActionButtonText}"
                                Background="#FF2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="18,10"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Click="HostedViewRunButton_Click" />
                    </Grid>
                </Grid>
            </Border>

            <!-- 3. Footer -->
            <Border Grid.Row="2" Background="#FF161616" CornerRadius="0,0,16,16" Padding="20,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="FooterAddExtensionButton"
                                Width="32"
                                Height="32"
                                Margin="0,0,10,0"
                                Background="Transparent"
                                BorderThickness="0"
                                ToolTip="添加扩展"
                                Click="FooterAddExtensionButton_Click"
                                Style="{StaticResource QuickMenuButtonStyle}">
                            <Path Data="M5,12 H19 M12,5 V19"
                                  Stroke="#FFE5E7EB"
                                  StrokeThickness="1.6"
                                  Height="14"
                                  Width="14"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"/>
                        </Button>
                        <Button x:Name="FooterQuickMenuButton"
                                Width="32"
                                Height="32"
                                Margin="0,0,12,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="FooterQuickMenuButton_Click"
                                Style="{StaticResource QuickMenuButtonStyle}">
                            <Path Data="M3,6H21V8H3V6ZM3,11H21V13H3V11ZM3,16H21V18H3V16Z" 
                                  Fill="#FF888888" Height="14" Width="14" Stretch="Uniform" HorizontalAlignment="Center"/>
                        </Button>
                        <TextBlock Text="{Binding FooterHint}" Foreground="#FF666666" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Actions" Foreground="#FF888888" FontSize="12" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                            <Border Background="#FF282828" CornerRadius="3" Padding="4,2" Margin="0,0,4,0" VerticalAlignment="Center">
                                <TextBlock Text="Ctrl" Foreground="#FF888888" FontSize="10"/>
                            </Border>
                            <Border Background="#FF282828" CornerRadius="3" Padding="4,2" VerticalAlignment="Center">
                                <TextBlock Text="K" Foreground="#FF888888" FontSize="10"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Popup x:Name="FooterQuickMenuPopup"
                           Placement="Top"
                           PlacementTarget="{Binding ElementName=FooterQuickMenuButton}"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           StaysOpen="False">
                        <Border Width="280"
                                Margin="0,0,0,16"
                                Background="#F21A1A1A"
                                BorderBrush="#25FFFFFF"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="25" Direction="270" ShadowDepth="4" Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel Margin="10">
                                <!-- Header Section -->
                                <StackPanel Margin="10,6,10,12">
                                    <TextBlock Text="快捷操作"
                                               Foreground="White"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="快速执行常用动作，无需搜索。"
                                               Foreground="#99FFFFFF"
                                               FontSize="11"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Separator Background="#12FFFFFF" Margin="6,0,6,8"/>

                                <Button Style="{StaticResource QuickMenuButtonStyle}"
                                        ToolTip="新建单文件 JSON 格式的扩展功能"
                                        Click="QuickMenuAddExtension_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Path Data="M5,12 H19 M12,5 V19" 
                                              Stroke="White" StrokeThickness="1.5" Height="16" Width="16" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.9"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="添加扩展" Foreground="#F0FFFFFF" FontSize="13" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Style="{StaticResource QuickMenuButtonStyle}"
                                        ToolTip="把程序内置技能组复制到外部文件夹进行编辑或备份"
                                        Click="QuickMenuInstallSkill_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Path Data="M12,3 L20,7 V17 L12,21 L4,17 V7 Z M12,3 V21 M4,7 L12,11 L20,7"
                                              Stroke="White" StrokeThickness="1.4" Height="16" Width="16" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.9"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="导出 Skill" Foreground="#F0FFFFFF" FontSize="13" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Style="{StaticResource QuickMenuButtonStyle}"
                                        ToolTip="进入设置页调整程序同步、外观及各项偏好"
                                        Click="QuickMenuOpenSettings_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
