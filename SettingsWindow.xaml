<Window x:Class="OpenQuickHost.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings"
        Width="1024"
        Height="768"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Colors -->
        <Color x:Key="SidebarBG">#FF1E1E1E</Color>
        <Color x:Key="ContentBG">#FF161616</Color>
        <Color x:Key="BorderColor">#FF2A2A2A</Color>
        <Color x:Key="AccentColor">#FF3B82F6</Color>
        <Color x:Key="TextMain">#FFFFFFFF</Color>
        <Color x:Key="TextSecondary">#FF8E8E8E</Color>
        
        <Style x:Key="SidebarListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="SidebarListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="10,2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Padding="12,8"
                                CornerRadius="8"
                                Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF2D2D2D" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF252525" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Switch Style (Raycast style) -->
        <Style x:Key="RaycastSwitchStyle" TargetType="CheckBox">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="36" Height="20">
                            <Border x:Name="Track"
                                    CornerRadius="10"
                                    Background="#FF333333" />
                            <Ellipse x:Name="Thumb"
                                    Width="16"
                                    Height="16"
                                    Margin="2,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Fill="White">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#FF3B82F6" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" 
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                           To="16" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" 
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                           To="0" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF666666" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF252525" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10"
            CornerRadius="12"
            Background="#FF161616"
            BorderBrush="#FF2A2A2A"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar (Left) -->
            <Border Grid.Column="0" 
                    Background="#FF1E1E1E" 
                    CornerRadius="12,0,0,12"
                    BorderBrush="#FF2A2A2A"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Margin="22,18,22,20"
                               Text="Settings"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF888888" />

                    <!-- Account Section -->
                    <Button Grid.Row="1"
                            Margin="10,0,10,15"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="AccountButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root" Background="Transparent" CornerRadius="8" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32"
                                                Height="32"
                                                CornerRadius="16"
                                                Background="#FF2D2D2D"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AccountInitial}"
                                                       FontSize="14"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AccountTitle}"
                                                       FontSize="13"
                                                       FontWeight="Medium"
                                                       Foreground="White" />
                                            <TextBlock Text="Account"
                                                       Foreground="#FF666666"
                                                       FontSize="11" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="#FF252525" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="AccountMenu">
                                <MenuItem Header="登录或切换账号" Click="SignInMenuItem_Click" />
                                <MenuItem Header="退出登录" Click="SignOutMenuItem_Click" />
                                <Separator />
                                <MenuItem Header="刷新云状态" Click="RefreshAccountMenuItem_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigation, Mode=TwoWay}"
                             Style="{StaticResource SidebarListBoxStyle}"
                             ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="20"
                                            Height="20"
                                            Background="Transparent"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Glyph}"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Text="{Binding Title}"
                                               FontSize="13"
                                               Foreground="White" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Content Area (Right) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Top Bar -->
                    <RowDefinition Height="*" />    <!-- Main Content -->
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Grid Grid.Row="0" Margin="15,10,15,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="‹" Style="{StaticResource NavButtonStyle}" Margin="0,0,5,0"/>
                        <Button Content="›" Style="{StaticResource NavButtonStyle}" />
                    </StackPanel>

                    <!-- Search Input -->
                    <Border Grid.Column="2" 
                            Margin="20,0,10,0" 
                            Background="#FF1E1E1E" 
                            CornerRadius="6" 
                            BorderBrush="#FF2A2A2A" 
                            BorderThickness="1"
                            Height="32"
                            Width="360"
                            HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⌕" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#FF666666" FontSize="14"/>
                            <TextBox Grid.Column="1" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     Foreground="White" 
                                     VerticalAlignment="Center"
                                     FontSize="13"/>
                            <TextBlock Grid.Column="1" 
                                       Text="Search by name or alias" 
                                       Foreground="#FF555555" 
                                       VerticalAlignment="Center" 
                                       IsHitTestVisible="False"
                                       FontSize="13"
                                       Margin="2,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Content="—" Style="{StaticResource NavButtonStyle}" Click="CloseButton_Click" VerticalAlignment="Center"/>
                        <Button Content="✕" Style="{StaticResource NavButtonStyle}" Click="CloseButton_Click" Margin="5,0,0,0"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="30,10,30,30">
                        
                        <!-- General Settings View -->
                        <StackPanel Visibility="{Binding IsGeneralSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="General" Foreground="#FF888888" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,15"/>
                            
                            <Grid Margin="0,5">
                                <TextBlock Text="Open at Login" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                <CheckBox HorizontalAlignment="Right" Style="{StaticResource RaycastSwitchStyle}" IsChecked="{Binding RefreshCloudOnStartup, Mode=TwoWay}" Click="SaveSettingsToggle_Click"/>
                            </Grid>
                            <Rectangle Height="1" Fill="#FF222222" Margin="0,12"/>

                            <Grid Margin="0,5">
                                <TextBlock Text="Show in System Tray" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                <CheckBox HorizontalAlignment="Right" Style="{StaticResource RaycastSwitchStyle}" IsChecked="{Binding CloseToTray, Mode=TwoWay}" Click="SaveSettingsToggle_Click"/>
                            </Grid>
                            <Rectangle Height="1" Fill="#FF222222" Margin="0,12"/>

                            <Grid Margin="0,5">
                                <TextBlock Text="Raycast Hotkey" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Background="#FF2D2D2D" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="Ctrl+Shift+Space" Foreground="White" FontSize="12"/>
                                    </Border>
                                    <Button Content="↻" Style="{StaticResource NavButtonStyle}" Width="24" Height="24"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Appearance" Foreground="#FF888888" FontSize="12" FontWeight="SemiBold" Margin="0,30,0,15"/>
                            
                            <Grid Margin="0,5">
                                <TextBlock Text="Follow System Appearance" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                <CheckBox HorizontalAlignment="Right" Style="{StaticResource RaycastSwitchStyle}" IsChecked="True"/>
                            </Grid>
                            <Rectangle Height="1" Fill="#FF222222" Margin="0,12"/>

                            <Grid Margin="0,5">
                                <TextBlock Text="Dark Theme" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                <Border Background="#FF2D2D2D" CornerRadius="4" Padding="10,4" HorizontalAlignment="Right">
                                    <TextBlock Text="Raycast Dark ▾" Foreground="White" FontSize="12"/>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- About View -->
                        <StackPanel Visibility="{Binding IsAboutSelected, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Stretch">
                            <StackPanel Margin="0,40,0,40" HorizontalAlignment="Center">
                                <Border Width="80" Height="80" CornerRadius="20" Background="Transparent" Margin="0,0,0,20">
                                    <Image x:Name="AboutLogoImage" Stretch="Uniform"/>
                                </Border>
                                <TextBlock Text="Swallow" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding AppVersionText}" Margin="0,5,0,0" Foreground="#FF666666" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="© 2026 Swallow Launcher. All Rights Reserved." Margin="0,10,0,0" Foreground="#FF555555" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="Links" Foreground="#FF888888" FontSize="12" FontWeight="SemiBold" Margin="0,20,0,10"/>
                            <Border Background="#FF1E1E1E" CornerRadius="8" BorderBrush="#FF2A2A2A" BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="15,12">
                                        <TextBlock Text="Website" Foreground="White" FontSize="13"/>
                                        <TextBlock Text="↗" Foreground="#FF555555" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Rectangle Height="1" Fill="#FF2A2A2A" Margin="15,0"/>
                                    <Grid Margin="15,12">
                                        <TextBlock Text="Send Feedback" Foreground="White" FontSize="13"/>
                                        <TextBlock Text="↗" Foreground="#FF555555" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Rectangle Height="1" Fill="#FF2A2A2A" Margin="15,0"/>
                                    <Grid Margin="15,12">
                                        <TextBlock Text="Twitter / X" Foreground="White" FontSize="13"/>
                                        <TextBlock Text="↗" Foreground="#FF555555" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Extensions/Shortcuts View -->
                        <StackPanel Visibility="{Binding IsExtensionsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="Extensions" Foreground="#FF888888" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <CheckBox HorizontalAlignment="Right" Content="" IsChecked="True"/>
                            </Grid>
                            
                            <Border Background="#FF1E1E1E" CornerRadius="8" BorderBrush="#FF2A2A2A" BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="15,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Name" Foreground="#FF666666" FontSize="11" Opacity="0.8"/>
                                        <TextBlock Grid.Column="2" Text="Alias" Foreground="#FF666666" FontSize="11" Margin="0,0,60,0" Opacity="0.8"/>
                                        <TextBlock Grid.Column="3" Text="Hotkey" Foreground="#FF666666" FontSize="11" Opacity="0.8"/>
                                    </Grid>
                                    <Rectangle Height="1" Fill="#FF2A2A2A" />
                                    
                                    <!-- Sample Row -->
                                    <Grid Margin="15,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="20" Height="20" CornerRadius="4" Background="#FF3B82F6"/>
                                        <TextBlock Grid.Column="1" Text="Local Storage Management" Foreground="White" FontSize="13" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        <TextBlock Grid.Column="2" Text="Add Alias" Foreground="#FF555555" FontSize="12" VerticalAlignment="Center" Margin="0,0,40,0"/>
                                        <TextBlock Grid.Column="3" Text="Record Hotkey" Foreground="#FF555555" FontSize="12" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        <CheckBox Grid.Column="4" IsChecked="True" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
