<Window x:Class="OpenQuickHost.QuickPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenQuickHost"
        mc:Ignorable="d"
        Title="快捷面板" Height="620" Width="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:BooleanToColorConverter x:Key="BooleanToColorConverter" />
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <local:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter" />
        
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlotButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0DFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F2121212" CornerRadius="20" BorderBrush="#FF333333" BorderThickness="1.5"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.6" ShadowDepth="0"/>
        </Border.Effect>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42"/> <!-- Sidebar -->
                <ColumnDefinition Width="*"/>  <!-- Main Content -->
            </Grid.ColumnDefinitions>

            <!-- 1. Left Sidebar -->
            <Border BorderBrush="#1AFFFFFF" BorderThickness="0,0,1,0" Padding="0,12">
                <Grid>
                    <StackPanel HorizontalAlignment="Center">
                        <!-- All / Grid icon - active when NOT showing favorites -->
                        <Button Style="{StaticResource SidebarButtonStyle}" Width="32" Height="32" ToolTip="全部"
                                Background="{Binding IsShowingFavorites, Converter={StaticResource BooleanToColorConverter}, ConverterParameter='Transparent|#1A3B82F6'}"
                                Click="SidebarAllButton_Click">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{Binding IsShowingFavorites, Converter={StaticResource BooleanToColorConverter}, ConverterParameter='#FF555555|#FF3B82F6'}">
                                        <Path.Data>M4,4H10V10H4V4M14,4H20V10H14V4M4,14H10V20H4V14M14,14H20V20H14V14Z</Path.Data>
                                    </Path>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <!-- Favorites / Star icon - active when showing favorites -->
                        <Button Style="{StaticResource SidebarButtonStyle}" Margin="0,6,0,0" Width="32" Height="32" ToolTip="收藏"
                                Background="{Binding IsShowingFavorites, Converter={StaticResource BooleanToColorConverter}, ConverterParameter='#1AFBBF24|Transparent'}"
                                Click="SidebarFavButton_Click">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{Binding IsShowingFavorites, Converter={StaticResource BooleanToColorConverter}, ConverterParameter='#FFFBBF24|#FF555555'}">
                                        <Path.Data>M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z</Path.Data>
                                    </Path>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                    
                    <!-- Settings icon -->
                    <Button Style="{StaticResource SidebarButtonStyle}" VerticalAlignment="Bottom" HorizontalAlignment="Center" Click="SettingsButton_Click" Width="32" Height="32" ToolTip="设置">
                        <Viewbox Width="16" Height="16">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8M12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12A2,2 0 0,0 12,10M10,22C9.75,22 9.54,21.82 9.5,21.58L9.13,18.93C8.5,18.68 7.96,18.34 7.44,17.94L4.95,18.95C4.73,19.03 4.46,18.95 4.34,18.73L2.34,15.27C2.21,15.05 2.27,14.78 2.46,14.63L4.57,12.97L4.5,12L4.57,11L2.46,9.37C2.27,9.22 2.21,8.95 2.34,8.73L4.34,5.27C4.46,5.05 4.73,4.96 4.95,5.05L7.44,6.05C7.96,5.66 8.5,5.32 9.13,5.07L9.5,2.42C9.54,2.18 9.75,2 10,2H14C14.25,2 14.46,2.18 14.5,2.42L14.87,5.07C15.5,5.32 16.04,5.66 16.56,6.05L19.05,5.05C19.27,4.96 19.54,5.05 19.66,5.27L21.66,8.73C21.79,8.95 21.73,9.22 21.54,9.37L19.43,11L19.5,12L19.43,13L21.54,14.63C21.73,14.78 21.79,15.05 21.66,15.27L19.66,18.73C19.54,18.95 19.27,19.04 19.05,18.95L16.56,17.95C16.04,18.34 15.5,18.68 14.87,18.93L14.5,21.58C14.46,21.82 14.25,22 14,22H10Z" Fill="#FF888888"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <!-- 2. Main Content -->
            <Grid Grid.Column="1" Margin="10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Scrollable content -->
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="燕子 Hub" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Background="#FF252525" CornerRadius="6" Padding="8,4" Width="110" Margin="0,0,5,0">
                            <Grid>
                                <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L19.71,19L18.29,20.41L13.03,15.15C11.9,16.13 10.42,16.71 8.86,16.71A7.86,7.86 0 0,1 1,8.86A7.86,7.86 0 0,1 8.86,1A7.86,7.86 0 0,1 9.5,3M8.86,3A5.86,5.86 0 0,0 3,8.86A5.86,5.86 0 0,0 8.86,14.71A5.86,5.86 0 0,0 14.71,8.86A5.86,5.86 0 0,0 8.86,3Z" 
                                      Fill="#FF555555" Width="10" Height="10" HorizontalAlignment="Left"/>
                                <TextBlock Text="搜索..." Foreground="#FF555555" FontSize="10" Margin="15,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Sections -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <!-- 常用 Section -->
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="常用" Foreground="#FFAAAAAA" FontSize="12" FontWeight="SemiBold"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Slots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SlotButtonStyle}" Margin="2" Click="SlotButton_Click" Tag="{Binding}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{Binding FavoriteLabel}" Click="ToggleFavorite_Click" CommandParameter="{Binding}"
                                                          Visibility="{Binding IsOccupied, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <Separator Visibility="{Binding IsOccupied, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <MenuItem Header="移除扩展" Click="RemoveExtension_Click" CommandParameter="{Binding}"
                                                          Visibility="{Binding IsOccupied, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <StackPanel Margin="0,6" HorizontalAlignment="Center">
                                            <Border Width="44" Height="44" CornerRadius="10" 
                                                    Background="{Binding Command.AccentBrush, FallbackValue='#FF1E1E1E'}" 
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,5">
                                                <Grid>
                                                    <!-- Empty: + icon via Viewbox -->
                                                    <Viewbox Width="18" Height="18"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Canvas Width="24" Height="24">
                                                            <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="#22FFFFFF"/>
                                                        </Canvas>
                                                    </Viewbox>
                                                    
                                                    <!-- Occupied -->
                                                    <Grid Visibility="{Binding IsOccupied, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Image Source="{Binding Icon}" Stretch="Uniform" Margin="8"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Visibility="{Binding Icon, Converter={StaticResource NotNullToVisibilityConverter}}"/>
                                                        <TextBlock Text="{Binding Command.Glyph}" Foreground="White" FontSize="18" FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Visibility="{Binding Icon, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                        <!-- Favorite indicator -->
                                                        <Border Width="10" Height="10" CornerRadius="5" Background="#FFFBBF24"
                                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,3,3,0"
                                                                Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding Title, FallbackValue='添加'}" 
                                                       Foreground="{Binding IsEmpty, Converter={StaticResource BooleanToColorConverter}, ConverterParameter='#FF444444|White'}" 
                                                       FontSize="10" TextAlignment="Center" Width="56" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- 扩展中心 Section Placeholder -->
                        <Grid Margin="0,15,0,8">
                            <TextBlock Text="扩展中心" Foreground="#FF555555" FontSize="12" FontWeight="SemiBold"/>
                        </Grid>
                        <Border Background="#0DFFFFFF" CornerRadius="10" Height="80" BorderBrush="#1AFFFFFF" BorderThickness="1">
                            <TextBlock Text="推荐中心" Foreground="#FF333333" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
