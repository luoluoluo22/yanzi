<Window x:Class="OpenQuickHost.WebDavCredentialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WebDAV 凭据"
        Width="460"
        MinHeight="280"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DialogWindow}">
    <Border Margin="15" CornerRadius="12" Background="#FF161616" BorderBrush="#FF2A2A2A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="设置 WebDAV 凭据" Style="{StaticResource TitleText}" />
            <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="用于坚果云或其他 WebDAV 服务。密码会使用 Windows DPAPI 本机加密保存。" Style="{StaticResource DescriptionText}" />

            <StackPanel x:Name="UsernamePanel" Grid.Row="2" Margin="0,20,0,0">
                <TextBlock Text="用户名" Foreground="#FFB8B8B8" FontSize="12" Margin="0,0,0,6" />
                <TextBox x:Name="UsernameBox" />
            </StackPanel>

            <StackPanel x:Name="CurrentUsernamePanel" Grid.Row="2" Margin="0,20,0,0" Visibility="Collapsed">
                <TextBlock Text="当前用户名" Foreground="#FFB8B8B8" FontSize="12" Margin="0,0,0,6" />
                <Border Background="#FF202020" BorderBrush="#FF2A2A2A" BorderThickness="1" CornerRadius="8" Padding="12,10">
                    <TextBlock x:Name="CurrentUsernameText" Foreground="White" />
                </Border>
            </StackPanel>

            <TextBlock Grid.Row="4" Margin="0,14,0,6" Text="密码 / 应用密码" Foreground="#FFB8B8B8" FontSize="12" />
            <PasswordBox x:Name="PasswordBox" Grid.Row="5" Height="40" Padding="12,10" VerticalAlignment="Top" />

            <Grid Grid.Row="6" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ErrorText" VerticalAlignment="Center" Foreground="#FFEF4444" FontSize="12" Visibility="Collapsed" />
                <Button Grid.Column="1" Content="取消" Style="{StaticResource SecondaryBtn}" Width="90" Margin="0,0,10,0" Click="CancelButton_Click" />
                <Button Grid.Column="2" Content="保存" Style="{StaticResource PrimaryBtn}" Width="90" Click="SaveButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
